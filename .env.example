# Example environment configuration for NGINX API Gateway
# Copy this file to .env and update with your values

# vCenter Configuration
VCENTER_HOST=vcenter.example.com
VCENTER_PORT=443

# Gateway Configuration
GATEWAY_LISTEN_PORT=443
GATEWAY_HTTP_PORT=80

# SSL Configuration
SSL_CERTIFICATE_PATH=/etc/nginx/ssl/gateway.crt
SSL_KEY_PATH=/etc/nginx/ssl/gateway.key

# Logging
LOG_LEVEL=warn
ACCESS_LOG_PATH=/var/log/nginx/vcenter-access.log
ERROR_LOG_PATH=/var/log/nginx/vcenter-error.log

# Performance Tuning
WORKER_PROCESSES=auto
WORKER_CONNECTIONS=1024
KEEPALIVE_CONNECTIONS=32

# Timeouts (in seconds)
PROXY_CONNECT_TIMEOUT=60
PROXY_SEND_TIMEOUT=300
PROXY_READ_TIMEOUT=300
